name: firestore-batch-incrementer
default_branch: main
config:
  description: "Iterates through a Firestore collection in batches and atomically increments a specified root‑level numeric field with configurable rate limiting."
  license: MIT
  language: go
  release: docker-go
  justfile: true
  status: active
  release_github: true
  codecov:
    enabled: true
  docs:
    enabled: false
